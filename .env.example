# ==========
# Docker
# ==========
# prefix for container names
PREFIX=
HOST_DATA_PATH=


# ================
# Oanda Listener
# ================
ACCOUNT_ID=
API_TOKEN=
INSTRUMENTS="EUR_USD"


# ================
# Redis
# ================
REDIS_PORT=6379
REDIS_EXT_PORT=6379
REDIS_HOST=redis
HOST_REDIS_PATH=


# ================
# Data paths
# ================
# All services derive paths from DATA_ROOT (landing, bronze, duckdb, etc.)
DATA_ROOT="/data"

# ================
# Stream writer
# ================
WRITER_BATCH_INTERVAL=60
BROKER_NAME=oanda

# ================
# Candle Builder
# ================
CANDLE_BUILDER_QUEUE_KEY="tick_queue:candle_builder"
CANDLE_FLUSH_INTERVAL=900
CANDLE_REDIS_TTL=172800

# ================
# Orchestrator / dbt
# ================
DAGSTER_EXT_PORT=3000
DELETE_AFTER_COMPACTION=true
